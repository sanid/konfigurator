{
  "name": "meco-konfigurator",
  "version": "2026.1.0",
  "description": "Meco Kitchen Cabinet Configurator - Electron/JSCAD Edition",
  "author": "Meco",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.meco.konfigurator",
    "productName": "Meco Konfigurator",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "**/*",
      "!dist/*",
      "!.claude/*",
      "!err*.log"
    ]
  },
  "dependencies": {
    "@jscad/modeling": "^2.13.0",
    "@jscad/openscad-openjscad-translator": "^0.0.11",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.3",
    "three": "^0.163.0"
  },
  "devDependencies": {
    "electron": "^30.1.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  }
}